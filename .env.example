# ============================================
# Konfigurasi Environment Magang Tracker Bot
# ============================================

# Telegram Bot Token (dapatkan dari @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# DeepSeek API Key (opsional, untuk ekstraksi AI)
# Dapatkan dari: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ============================================
# Catatan:
# 1. Copy file ini ke .env: cp .env.example .env
# 2. Isi nilai token dan API key Anda
# 3. File .env sudah di-ignore oleh Git (lihat .gitignore)
# ============================================

